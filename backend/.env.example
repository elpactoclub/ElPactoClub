# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (local dev) ─────────────────────────────────────────────────────
# In production, Fly.io sets DATABASE_URL automatically after `fly postgres attach`
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_db_password
DB_NAME=elpactodb

# DATABASE_URL=postgresql://user:pass@host:5432/db  # used in production

# Set DB_SYNCHRONIZE=true on first Fly.io deploy to create tables, then remove
DB_SYNCHRONIZE=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-secret

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ── Stripe (optional — app starts fine without these) ────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SOCIO=price_...
