# App
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_db_password_here
DB_NAME=elpactodb

# JWT (genera una clave fuerte y única en producción)
JWT_SECRET=change-me-use-a-long-random-secret

# Frontend
FRONTEND_URL=http://localhost:3000

# Stripe (add when ready)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SOCIO=price_...

# Supabase (alternative auth, optional)
# SUPABASE_URL=https://xxx.supabase.co
